<![CDATA[ecmascript:

function initialize ()
{
   eventsProcessed .call (this);
}

function eventsProcessed ()
{
   const 
      mirrorNormal      = mirrorRotation .multVec (SFVec3f .Z_AXIS),
      viewpointToMirror = mirrorTranslation .subtract (viewpointPosition);

   const rDirection = viewpointToMirror .reflect (mirrorNormal);

   mirrorViewpointPosition_changed = mirrorTranslation .subtract (rDirection);

   const
      forward = viewpointOrientation .multVec (SFVec3f .Z_AXIS),
      up      = viewpointOrientation .multVec (SFVec3f .Y_AXIS);

   const
      rForward = forward .reflect (mirrorNormal),
      rUp      = up .reflect (mirrorNormal),
      rRight   = rUp .cross (rForward) .normalize ();

   mirrorViewpointOrientation_changed = new SFRotation (new SFMatrix3f (rRight, rUp, rForward));

   mirrorViewpointFieldOfView_changed = Math .atan (Math .min (... mirrorScale) / viewpointToMirror .length ()) * 2;
}
]]>
