}

function eventsProcessed ()
{
   const 
      mirrorNormal      = mirrorRotation .multVec (new SFVec3f (0, 0, 1)),
      viewpointToMirror = mirrorTranslation .subtract (viewpointPosition);

   const rDirection = reflect (viewpointToMirror, mirrorNormal);

   mirrorViewpointPosition_changed = mirrorTranslation .subtract (rDirection);

   mirrorViewpointOrientation_changed = new SFRotation (new SFVec3f (0, 0, 1), rDirection .negate ()) .straighten ();
}

function reflect (i, n)
{
   return i .subtract (n .multiply (2.0 * n .dot (i)));
}
