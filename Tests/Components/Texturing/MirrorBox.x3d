            <connect nodeField='textureSize' protoField='textureSize'/>
          </IS>
<![CDATA[ecmascript:

function initialize ()
{
   const getProjectionMatrixWithLimits = mirrorViewpoint .getValue () .getProjectionMatrixWithLimits;

   mirrorViewpoint .getValue () .getProjectionMatrixWithLimits = function (nearValue, farValue, viewport)
   {
      const projectionMatrix = getProjectionMatrixWithLimits .call (this, nearValue, farValue, viewport);

      const viewMatrix = new SFMatrix4f (mirrorViewpoint .getValue () .getViewMatrix () .copy ());

      // Update the texture matrix
      let textureMatrix = new SFMatrix4f (
         0.5,   0,   0, 0,
           0, 0.5,   0, 0,
           0,   0, 0.5, 0,
         0.5, 0.5, 0.5, 1,
      );

      textureMatrix = textureMatrix .multLeft (new SFMatrix4f (projectionMatrix .copy ()));
      textureMatrix = textureMatrix .multLeft (viewMatrix);

     //mirrorTextureMatrix_changed = textureMatrix;


      let reflectorPlane = new Plane (mirrorRotation .multVec (SFVec3f .Z_AXIS), mirrorTranslation);

      reflectorPlane = reflectorPlane .multLeft (viewMatrix);

		  let clipPlane = new SFVec4f (... reflectorPlane .normal, reflectorPlane .distanceFromOrigin);
      let q = new SFVec4f ();

      q .x = (Math .sign (clipPlane .x) + projectionMatrix [8]) / projectionMatrix [0];
      q .y = (Math .sign (clipPlane .y) + projectionMatrix [9]) / projectionMatrix [5];
      q .z = -1;
      q .w = (1 + projectionMatrix [10]) / projectionMatrix [14];

      clipPlane = clipPlane .multiply (2 / clipPlane .dot (q));

      // Replacing the third row of the projection matrix
      projectionMatrix [2]  = clipPlane .x;
      projectionMatrix [6]  = clipPlane .y;
      projectionMatrix [10] = clipPlane .z + 1.0 + 0.003;
      projectionMatrix [14] = clipPlane .w;

      return projectionMatrix;
   }

   set_textureSize ();
   eventsProcessed ();
}

function set_mirrorScale ()
{
   set_textureSize ();
}

function set_textureSize ()
{
   const
      x = mirrorScale .x,
      y = mirrorScale .y,
      w = x >= y ? textureSize : x * textureSize / y,
      h = y >= x ? textureSize : y * textureSize / x;

   textureDimension_changed = new MFInt32 (w, h, 4, 1, 1);
}

function eventsProcessed ()
{
   const
      mirrorNormal      = mirrorRotation .multVec (SFVec3f .Z_AXIS),
      viewpointToMirror = mirrorTranslation .subtract (viewpointPosition);

   const rDirection = viewpointToMirror .reflect (mirrorNormal);

   mirrorViewpointPosition_changed = mirrorTranslation .subtract (rDirection);

   const
      rForward  = viewpointOrientation .multVec (SFVec3f .Z_AXIS) .reflect (mirrorNormal),
      tUp       = mirrorRotation .multVec (SFVec3f .Y_AXIS),
      rRight    = tUp .cross (rForward) .normalize (),
      rUp       = rForward .cross (rRight) .normalize ();

   mirrorViewpointOrientation_changed = new SFRotation (new SFMatrix3f (rRight, rUp, rForward));
}

class Plane
{
   constructor (normal, point)
   {
      this .normal             = normal .copy ();
      this .distanceFromOrigin = normal .dot (point);
   }

   multRight (matrix)
   {
      // Taken from Inventor:

      // Find the point on the plane along the normal from the origin
      let point = this .normal .multiply (this .distanceFromOrigin);

      // Transform the plane normal by the matrix
      // to get the new normal. Use the inverse transpose
      // of the matrix so that normals are not scaled incorrectly.
      // n' = n * !~m = ~m * n
      this .normal = matrix .inverse ()
         .multMatrixDir (this .normal) .normalize ();

      // Transform the point by the matrix
      point = matrix .multVecMatrix (point);

      // The new distance is the projected distance of the vector to the
      // transformed point onto the (unit) transformed normal. This is
      // just a dot product.
      this .distanceFromOrigin = this .normal .dot (point);

      return this;
   }

   multLeft (matrix)
   {
      // Taken from Inventor:

      // Find the point on the plane along the normal from the origin
      let point = this .normal .multiply (this .distanceFromOrigin);

      // Transform the plane normal by the matrix
      // to get the new normal. Use the inverse transpose
      // of the matrix so that normals are not scaled incorrectly.
      // n' = n * !~m = ~m * n
      this .normal = matrix .inverse ()
         .multDirMatrix (this .normal) .normalize ();

      // Transform the point by the matrix
     point = matrix .multMatrixVec (point);

      // The new distance is the projected distance of the vector to the
      // transformed point onto the (unit) transformed normal. This is
      // just a dot product.
      this .distanceFromOrigin = this .normal .dot (point);

      return this;
   }
}]]>
