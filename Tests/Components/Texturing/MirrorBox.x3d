          <field accessType='inputOutput' type='SFRotation' name='viewpointOrientation' value='-0.914589430575436 -0.403127310041776 -0.0318519289558134 9.87512509009108'/>
          <field accessType='outputOnly' type='MFInt32' name='textureDimension_changed'/>
          <field accessType='outputOnly' type='SFVec3f' name='mirrorViewpointPosition_changed'/>
          <field accessType='outputOnly' type='SFRotation' name='mirrorViewpointOrientation_changed'/>
          <field accessType='outputOnly' type='SFFloat' name='mirrorViewpointFieldOfView_changed'/>
          <field accessType='outputOnly' type='SFMatrix4f' name='mirrorTextureMatrix_changed'/>
          <IS>
            <connect nodeField='mirrorTranslation' protoField='translation'/>
            <connect nodeField='mirrorRotation' protoField='rotation'/>
            <connect nodeField='mirrorScale' protoField='scale'/>
            <connect nodeField='textureSize' protoField='textureSize'/>
          </IS>
<![CDATA[ecmascript:

function initialize ()
{
   set_textureSize ();
   eventsProcessed ();
}

function set_mirrorScale ()
{
   set_textureSize ();
}

function set_textureSize ()
{
   const
      x = mirrorScale .x,
      y = mirrorScale .y,
      w = x >= y ? textureSize : x * textureSize / y,
      h = y >= x ? textureSize : y * textureSize / x;

   textureDimension_changed = new MFInt32 (w, h, 4, 1, 1);
}

function eventsProcessed ()
{
   const
      mirrorNormal      = mirrorRotation .multVec (SFVec3f .Z_AXIS),
      viewpointToMirror = mirrorTranslation .subtract (viewpointPosition);

   const rDirection = viewpointToMirror .reflect (mirrorNormal);

   mirrorViewpointPosition_changed = mirrorTranslation .subtract (rDirection);

   //const
   //   rForward  = viewpointOrientation .multVec (SFVec3f .Z_AXIS) .reflect (mirrorNormal),
   //   tUp       = mirrorRotation .multVec (SFVec3f .Y_AXIS),
   //   rRight    = tUp .cross (rForward) .normalize (),
   //   rUp       = rForward .cross (rRight) .normalize ();

   //mirrorViewpointOrientation_changed = new SFRotation (new SFMatrix3f (rRight, rUp, rForward));


   const
      rForward  = mirrorViewpointPosition_changed .subtract (mirrorTranslation) .normalize (),
      tUp       = mirrorRotation .multVec (SFVec3f .Y_AXIS),
      rRight    = tUp .cross (rForward) .normalize (),
      rUp       = rForward .cross (rRight) .normalize ();

   mirrorViewpointOrientation_changed = new SFRotation (new SFMatrix3f (rRight, rUp, rForward));

   mirrorViewpointFieldOfView_changed = Math .atan (Math .min (mirrorScale .x, mirrorScale .y) / viewpointToMirror .length ()) * 3; // Use 3 instead of 2 to make the fov a bit larger.

   // Texture matrix

   const projectionMatrix = Camera .perspective (mirrorViewpointFieldOfView_changed, 0.125, 2_000, mirrorScale .x, mirrorScale .y);

   let viewMatrix = new SFMatrix4f () 
   
   viewMatrix .setTransform (mirrorViewpointPosition_changed, mirrorViewpointOrientation_changed);

   viewMatrix = viewMatrix .inverse ();

   // Update the texture matrix
   let textureMatrix = new SFMatrix4f (
      0.5,   0,   0, 0,
        0, 0.5,   0, 0,
        0,   0, 0.5, 0,
      0.5, 0.5, 0.5, 1,
   );

   const modelMatrix = new SFMatrix4f ();
   modelMatrix .setTransform (mirrorTranslation, mirrorRotation, mirrorScale);

   const offset = new SFMatrix4f (
       2,  0, 0, 0,
       0,  2, 0, 0,
       0,  0, 1, 0,
      -1, -1, 0, 1,
   );

   textureMatrix = textureMatrix
      .multLeft (projectionMatrix)
      .multLeft (viewMatrix)
      .multLeft (modelMatrix)
      .multLeft (offset);

   mirrorTextureMatrix_changed = textureMatrix;
}

const Camera =
{
   frustum (l, r, b, t, n, f)
   {
      const
         r_l = r - l,
         t_b = t - b,
         f_n = f - n,
         n_2 = 2 * n,

         A = (r + l) / r_l,
         B = (t + b) / t_b,
         C = -(f + n) / f_n,
         D = -(n_2 * f) / f_n,
         E = n_2 / r_l,
         F = n_2 / t_b;

      return new SFMatrix4f (E, 0, 0, 0,
                             0, F, 0, 0,
                             A, B, C, -1,
                             0, 0, D, 0);
   },
   perspective (fieldOfView, zNear, zFar, width, height)
   {
      const ratio = Math .tan (fieldOfView / 2) * zNear;

      if (width > height)
      {
         const aspect = width * ratio / height;

         return this .frustum (-aspect, aspect, -ratio, ratio, zNear, zFar);
      }
      else
      {
         const aspect = height * ratio / width;

         return this .frustum (-ratio, ratio, -aspect, aspect, zNear, zFar);
      }
   },
};]]>
