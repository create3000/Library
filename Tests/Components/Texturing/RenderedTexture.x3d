<![CDATA[data:x-shader/x-fragment,#version 300 es

precision highp float;
precision highp int;

in vec2 texCoord;

out vec4 x3d_FragColor;

uniform sampler2D renderedTexture;

void
main ()
{
   x3d_FragColor = texture (renderedTexture, texCoord);
}
]]>
