              <ShaderPart DEF='VertexShader_1'>
<![CDATA[data:x-shader/x-vertex,#version 300 es

precision highp float;
precision highp int;

uniform mat4 x3d_ProjectionMatrix;
uniform mat4 x3d_ModelViewMatrix;

in vec4 x3d_TexCoord0;
in vec4 x3d_Vertex;

out vec2 texCoord;

void
main ()
{
   texCoord = vec2 (x3d_TexCoord0 .xy);

   gl_Position = x3d_ProjectionMatrix * x3d_ModelViewMatrix * x3d_Vertex;
}
]]>
              </ShaderPart>
              <ShaderPart DEF='FragmentShader_1'
                  type='FRAGMENT'>
<![CDATA[data:x-shader/x-fragment,#version 300 es

precision highp float;
precision highp int;

in vec2 texCoord;

out vec4 x3d_FragColor;

uniform sampler2D renderedTexture;

void
main ()
{
   x3d_FragColor = texture (renderedTexture, texCoord);
}
]]>
              </ShaderPart>
            </ComposedShader>
